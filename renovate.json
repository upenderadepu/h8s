{
    "$schema": "https://docs.renovatebot.com/renovate-schema.json",
    "registryAliases": {
        "harbor.okwilkins.dev/docker-hub-cache": "index.docker.io",
        "harbor.okwilkins.dev/ghcr-cache": "ghcr.io"
    },
    "dependencyDashboard": true,
    "automerge": false,
    "prHourlyLimit": 0,
    "prConcurrentLimit": 0,
    "argocd": {
        "managerFilePatterns": [
            "/ci-cd/argocd/.*/.*\\.ya?ml$/"
        ]
    },
    "kubernetes": {
        "managerFilePatterns": [
            "/.*\\.yaml$/",
            "/.*\\.yml$/"
        ],
        "ignorePaths": [
            "infrastructure/",
            "**/docker-compose*.yaml"
        ]
    },
    "terraform": {},
    "nix": {
        "enabled": true
    },
    "lockFileMaintenance": {
        "enabled": true
    },
    "customManagers": [
        {
            "customType": "regex",
            "description": "Update Kustomize remote resource URLs",
            "managerFilePatterns": [
                "/.*/kustomization\\.yaml$/"
            ],
            "matchStrings": [
                "-\\s+https://raw\\.githubusercontent\\.com/(?<depName>[^/]+/[^/]+)/(?<currentValue>[^/]+)/.*"
            ],
            "datasourceTemplate": "github-tags",
            "versioningTemplate": "semver"
        },
        {
            "customType": "regex",
            "description": "Update CloudNativePG PostgreSQL images",
            "managerFilePatterns": [
                "/storage/cloudnative-pg/.*\\.yaml$/"
            ],
            "matchStrings": [
                "imageName:\\s+(?<depName>[^\\s]+):(?<currentValue>[^\\s]+)"
            ],
            "datasourceTemplate": "docker",
            "versioningTemplate": "loose"
        }
    ],
    "packageRules": [
        {
            "description": "Label major updates for manual review",
            "matchUpdateTypes": [
                "major"
            ],
            "labels": [
                "dependencies",
                "major-update"
            ]
        },
        {
            "description": "CloudNativePG images from ghcr.io",
            "matchDatasources": [
                "docker"
            ],
            "matchPackageNames": [
                "ghcr.io/cloudnative-pg/**"
            ],
            "enabled": true
        },
        {
            "description": "Force docker datasource for OCI Helm charts (ghcr.io)",
            "matchDatasources": [
                "docker"
            ],
            "matchPackageNames": [
                "ghcr.io/grafana/helm-charts/grafana-operator"
            ],
            "enabled": true
        },
        {
            "description": "Resolve images via Harbor docker-hub-cache proxy against Docker Hub",
            "matchDatasources": [
                "docker"
            ],
            "matchPackageNames": [
                "harbor.okwilkins.dev/docker-hub-cache/**"
            ],
            "registryUrls": [
                "https://index.docker.io"
            ],
            "overrideDepName": "{{replace 'harbor\\.okwilkins\\.dev/docker-hub-cache/' '' depName}}",
            "enabled": true
        },
        {
            "description": "Resolve images via Harbor ghcr-cache proxy against GHCR",
            "matchDatasources": [
                "docker"
            ],
            "matchPackageNames": [
                "harbor.okwilkins.dev/ghcr-cache/**"
            ],
            "registryUrls": [
                "https://ghcr.io"
            ],
            "overrideDepName": "{{replace 'harbor\\.okwilkins\\.dev/ghcr-cache/' '' depName}}",
            "enabled": true
        }
    ]
}
